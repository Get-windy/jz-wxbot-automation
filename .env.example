# jz-wxbot 环境配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=jz-wxbot
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ==================== 服务角色 ====================
# coordinator: 任务协调器
# worker: 工作节点（微信自动化）
ROLE=coordinator

# ==================== 实例配置 ====================
INSTANCE_ID=wxbot-1
WORKER_ID=

# ==================== OpenClaw 集成 ====================
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:3100
OPENCLAW_AGENT_ID=wxbot-agent

# ==================== 数据库配置 ====================
# SQLite (开发环境)
DATABASE_URL=sqlite:///data/wxbot.db

# MySQL (生产环境)
# DATABASE_URL=mysql://user:password@localhost:3306/wxbot

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql://user:password@localhost:5432/wxbot

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 安全配置 ====================
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production
ENCRYPTION_KEY=your-encryption-key-32-chars

# ==================== 微信配置 ====================
# 微信个人号
WECHAT_ENABLED=true
WECHAT_PROCESS_NAMES=WeChat.exe,Weixin.exe

# 企业微信
WXWORK_ENABLED=true
WXWORK_PROCESS_NAMES=WXWork.exe

# ==================== 人性化操作配置 ====================
HUMAN_LIKE_ENABLED=true
HUMAN_LIKE_MIN_DELAY=0.5
HUMAN_LIKE_MAX_DELAY=2.0
HUMAN_LIKE_CURVE_MOVEMENT=true

# ==================== 监控配置 ====================
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_PORT=9000

# ==================== 告警配置 ====================
ALERT_ENABLED=true
ALERT_DINGTALK_WEBHOOK=
ALERT_EMAIL_RECIPIENTS=

# ==================== Docker 配置 ====================
COMPOSE_PROJECT_NAME=jzwxbot
GRAFANA_PASSWORD=admin123

# ==================== 开发配置 ====================
PYTHONUNBUFFERED=1
PYTHONPATH=/app
PYTHONDONTWRITEBYTECODE=1